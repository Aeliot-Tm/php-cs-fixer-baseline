{
    "name": "aeliot/php-cs-fixer-baseline",
    "type": "library",
    "description": "Baseline for PHP CS Fixer",
    "license": "MIT",
    "authors": [
        {
            "name": "Anatoliy Melnikov",
            "email": "5785276@gmail.com"
        }
    ],
    "minimum-stability": "dev",
    "prefer-stable": true,
    "require": {
        "php": "^8.0",
        "ext-mbstring": "*",
        "composer-runtime-api": "^2.2",
        "friendsofphp/php-cs-fixer": "^3.0",
        "psr/container": "^1.1 || ^2.0",
        "symfony/config": "^4.4.20 || ^5.0 || ^6.0 || ^7.0 || ^8.0",
        "symfony/console": "^4.4.20 || ^5.0 || ^6.0 || ^7.0 || ^8.0",
        "symfony/dependency-injection": "^4.4.20 || ^5.0 || ^6.0 || ^7.0 || ^8.0",
        "symfony/yaml": "^4.4.20 || ^5.0 || ^6.0 || ^7.0 || ^8.0"
    },
    "require-dev": {
        "dg/bypass-finals": "^1.7",
        "phpstan/extension-installer": "^1.3",
        "phpstan/phpstan": "^1.11",
        "phpstan/phpstan-phpunit": "^1.4",
        "phpunit/phpunit": "^9.6||^11.5"
    },
    "autoload": {
        "psr-4": {
            "Aeliot\\PhpCsFixerBaseline\\": "src/"
        }
    },
    "autoload-dev": {
        "psr-4": {
            "Aeliot\\PhpCsFixerBaseline\\Test\\Functional\\": "tests/functional/",
            "Aeliot\\PhpCsFixerBaseline\\Test\\Unit\\": "tests/unit/"
        }
    },
    "bin": [
        "bin/pcsf-baseline"
    ],
    "config": {
        "allow-plugins": {
            "composer/*": true,
            "phpstan/extension-installer": true
        },
        "platform": {
            "php": "8.0.30"
        },
        "sort-packages": true
    },
    "keywords": [
        "PHP CS Fixer",
        "baseline"
    ],
    "scripts": {
        "build": [
            "php .infra/scripts/box/prepare-config.php",
            "tools/box.phar compile --config=.infra/scripts/box/config.json"
        ],
        "cs-check": "@cs-fixer-check",
        "cs-fix": "@cs-fixer-fix",
        "cs-fixer-check": "@cs-fixer-fix --dry-run",
        "cs-fixer-fix": "vendor/bin/php-cs-fixer fix -vv --config=.infra/scripts/php-cs-fixer/config.php",
        "phive-install": "phive install --trust-gpg-keys $(cat .phive/trust-gpg-keys.txt)",
        "phpstan": [
            "@phpstan-clear",
            "@phpstan-analyse"
        ],
        "phpstan-analyse": "vendor/bin/phpstan analyse -c .infra/scripts/phpstan/config.neon --memory-limit=-1",
        "phpstan-baseline": [
            "@phpstan-clear",
            "@phpstan-analyse --generate-baseline .infra/scripts/phpstan/baseline.neon --allow-empty-baseline"
        ],
        "phpstan-clear": "vendor/bin/phpstan clear-result-cache",
        "phpunit": "vendor/bin/phpunit -c .infra/scripts/phpunit/config.xml",
        "require-check": "tools/composer-require-checker.phar check --config-file=.infra/scripts/composer-require-checker/config.json composer.json --output=text",
        "test-all": "@phpunit",
        "test-func": "@phpunit --testsuite functional",
        "test-unit": "@phpunit --testsuite unit",
        "unused": "XDEBUG_MODE=off tools/composer-unused.phar unused -c .infra/scripts/composer-unused/config.php"
    }
}
